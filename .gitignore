# Ignoriere Kunden-Daten (Rechnungen, Buchhaltung, Personenbezogene Daten)
Kunden/*
!Kunden/.gitkeep

# Ignoriere sensible API Keys
Systemdaten/gemini_api_key.txt
.env
Systemdaten/gemini_key.env

# Ignoriere Python Caches
**/__pycache__/
*.pyc

# Ignoriere temporäre/generierte Excel-Dateien, aber behalte die Systemdaten-Regeln
**/Excel_Sammlung/
**/Excel_Sammlung/*
**/Excel_Sammlung/*.xlsx
*.xlsx
!Systemdaten/*.xlsx
